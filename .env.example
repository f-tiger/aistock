# --- Live quotes (optional) ---
# The site works fully WITHOUT these — live prices simply show "—".
#
# Finnhub API key, used ONLY by the Cloudflare Pages Function (functions/api/quote.ts).
# Set it in Cloudflare → Pages → Settings → Environment variables (as a Secret),
# NOT committed and NOT exposed to the browser. Get a free key at https://finnhub.io
FINNHUB_API_KEY=

# Optional: override the quote/candles endpoints the browser calls.
# Default to "/api/quote" and "/api/candles" (the Pages Functions). Exposed to the client.
# NEXT_PUBLIC_QUOTE_ENDPOINT=/api/quote
# NEXT_PUBLIC_CANDLES_ENDPOINT=/api/candles

# Canonical site URL for SEO (sitemap.xml, robots.txt, OpenGraph). Exposed to the client.
# NEXT_PUBLIC_SITE_URL=https://your-domain.pages.dev
