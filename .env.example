# --- Live quotes (optional) ---
# The site works fully WITHOUT these — live prices simply show "—".
#
# Finnhub API key, used ONLY by the Cloudflare Pages Function (functions/api/quote.ts).
# Set it in Cloudflare → Pages → Settings → Environment variables (as a Secret),
# NOT committed and NOT exposed to the browser. Get a free key at https://finnhub.io
FINNHUB_API_KEY=

# Optional: override the quote/candles endpoints the browser calls.
# Default to "/api/quote" and "/api/candles" (the Pages Functions). Exposed to the client.
# NEXT_PUBLIC_QUOTE_ENDPOINT=/api/quote
# NEXT_PUBLIC_CANDLES_ENDPOINT=/api/candles

# Canonical site URL for SEO (sitemap.xml, robots.txt, OpenGraph). Exposed to the client.
# NEXT_PUBLIC_SITE_URL=https://your-domain.pages.dev

# --- Conversion funnel (optional) ---
# Newsletter: the form posts to /api/subscribe (functions/api/subscribe.ts), which
# needs a Cloudflare KV namespace bound as SUBSCRIBERS (Pages → Settings → Bindings).
# Or point the form at any external endpoint (e.g. Buttondown/Mailchimp):
# NEXT_PUBLIC_SUBSCRIBE_ENDPOINT=/api/subscribe

# Telegram: get a real-time DM the moment someone subscribes (owner alert).
# 1) Create a bot via @BotFather → copy the token.  2) Send your bot any message,
# then open https://api.telegram.org/bot<TOKEN>/getUpdates to read your chat id.
# Set BOTH in Cloudflare → Pages → Settings → Environment variables (as Secrets).
# Without them, subscriptions still work; the notification is simply skipped.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Welcome email (optional): if set, /api/subscribe sends a welcome email via Resend.
# Create a key at https://resend.com and verify a sending domain; FROM must be on it.
# Without these, no email is sent (subscription still succeeds).
RESEND_API_KEY=
RESEND_FROM="AI Investing Compass <hello@your-domain.com>"

# Cloudflare Web Analytics beacon token (dashboard → Web Analytics → add site).
# Without it, no analytics script is emitted at all.
# NEXT_PUBLIC_CF_ANALYTICS_TOKEN=

# Broker referral links live in lib/data/brokers.ts — swap the URLs for your
# affiliate links to activate the revenue channel.
